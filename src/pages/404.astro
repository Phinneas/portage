---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found · Portage" description="This page has drifted off the chart." navVariant="landing">
  <section class="sec" style="padding:140px 0 100px; text-align:center;">
    <div class="wrap">
      <span class="kicker reveal">// Off the chart</span>
      <h1 class="reveal" style="font-size:clamp(48px,10vw,120px); letter-spacing:-0.03em; margin-top:20px;">404</h1>
      <p class="reveal" style="color:var(--text-dim); font-size:19px; max-width:420px; margin:24px auto 0;">This page has drifted off the chart. No sounding found at this coordinate.</p>
      <div class="cta-row reveal" style="justify-content:center; margin-top:40px;">
        <a href="/" class="btn btn-primary">Return to port <span class="arr">→</span></a>
        <a href="/#routes" class="btn btn-ghost">View the Routes</a>
      </div>
      <div class="reveal" style="margin-top:80px; font-family:var(--mono); font-size:12px; color:var(--text-faint); letter-spacing:0.08em;">
        <span style="display:inline-block; border:1px solid var(--line); border-radius:3px; padding:8px 14px; background:var(--surface);">
          Bearing unknown · 48.4284° N · 123.3656° W
        </span>
      </div>
    </div>
  </section>
</Layout>
