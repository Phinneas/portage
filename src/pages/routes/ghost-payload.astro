    <h3>Seed script (generated)</h3>
    <div class="code">
      <div class="code-bar"><span class="name">src/seed.ts (excerpt)</span><span class="meta">typescript</span></div>
      <pre is:raw"><span class="k">import</span> { getPayload } <span class="k">from</span> <span class="s">'payload'</span>;
<span class="k">import</span> config <span class="k">from</span> <span class="s">'@payload-config'</span>;
<span class="k">import</span> path <span class="k">from</span> <span class="s">'node:path'</span>;

<span class="k">const</span> payload = <span class="k">await</span> getPayload({ config });

<span class="c">// 1. Create tags (relationship targets first)</span>
<span class="k">const</span> tagMap: Record&lt;string, <span class="ty">string</span>&gt; = {};
<span class="k">for</span> (<span class="k">const</span> t <span class="k">of</span> tags) {
  <span class="k">const</span> doc = <span class="k">await</span> payload.create({
    collection: <span class="s">'tags'</span>,
    data: { name: t.name, slug: t.slug },
    overrideAccess: <span class="k">true</span>,
  });
  tagMap[t.id] = doc.id;
}

<span class="c">// 2. Create media (upload images)</span>
<span class="k">const</span> mediaMap: Record&lt;string, <span class="ty">string</span>&gt; = {};
<span class="k">for</span> (<span class="k">const</span> img <span class="k">of</span> images) {
  <span class="k">const</span> doc = <span class="k">await</span> payload.create({
    collection: <span class="s">'media'</span>,
    data: { alt: img.alt },
    filePath: path.resolve(<span class="s">'./media/'</span>, img.filename),
    overrideAccess: <span class="k">true</span>,
  });
  mediaMap[img.ghostUrl] = doc.id;
}

<span class="c">// 3. Create authors</span>
<span class="k">const</span> authorMap: Record&lt;string, <span class="ty">string</span>&gt; = {};
<span class="k">for</span> (<span class="k">const</span> a <span class="k">of</span> authors) {
  <span class="k">const</span> doc = <span class="k">await</span> payload.create({
    collection: <span class="s">'authors'</span>,
    data: {
      name: a.name, slug: a.slug,
      profileImage: a.profileImage ? mediaMap[a.profileImage] : undefined,
    },
    overrideAccess: <span class="k">true</span>,
  });
  authorMap[a.id] = doc.id;
}

<span class="c">// 4. Create posts (references resolved)</span>
<span class="k">for</span> (<span class="k">const</span> p <span class="k">of</span> posts) {
  <span class="k">await</span> payload.create({
    collection: <span class="s">'posts'</span>,
    data: {
      title: p.title, slug: p.slug,
      content: p.lexical,  <span class="c">// Lexical JSON</span>
      featureImage: p.featureImage ? mediaMap[p.featureImage] : undefined,
      publishedAt: p.publishedAt,
      tags: p.tagIds.map((id: <span class="ty">string</span>) => tagMap[id]),
      authors: p.authorIds.map((id: <span class="ty">string</span>) => authorMap[id]),
    },
    overrideAccess: <span class="k">true</span>,
  });
}

console.log(<span class="s">'Seed complete.'</span>);</pre>
    </div>
    <div class="note">
      <span class="lbl">Running the seed</span>
      <p>Execute with <code>payload run src/seed.ts</code>. This loads environment variables the same way Next.js does and initializes tsx for TypeScript execution. Payload must have been started at least once to push the schema to SQLite.</p>
    </div>
