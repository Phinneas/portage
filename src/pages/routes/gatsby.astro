  { k: 'Spec rev', v: '2026.06 · r2' },
];

const toc = [
  { id: 's01', num: '01', label: 'Overview' },
  { id: 's02', num: '02', label: 'Extraction' },
  { id: 's03', num: '03', label: 'Content mapping' },
  { id: 's04', num: '04', label: 'Transforms' },
  { id: 's05', num: '05', label: 'Assets' },
  { id: 's06', num: '06', label: 'Routes & redirects' },
