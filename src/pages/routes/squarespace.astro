import SpecLayout from '../../layouts/SpecLayout.astro';

const meta = [
  { k: 'Source', v: 'Squarespace 7.0 / 7.1' },
  { k: 'Method', v: 'WordPress XML (WXR) + crawl', cy: true },
  { k: 'Output', v: 'Markdown · MDX' },
  { k: 'Target', v: 'Content collections', cy: true },
  { k: 'Spec rev', v: '2026.06 · r2' },
];

const toc = [
  { id: 's01', num: '01', label: 'Overview' },
  { id: 's02', num: '02', label: 'Export' },
  { id: 's03', num: '03', label: 'Content mapping' },
  { id: 's04', num: '04', label: 'Transforms' },
  { id: 's05', num: '05', label: 'Assets' },
  { id: 's06', num: '06', label: 'Routes & redirects' },
  { id: 's07', num: '07', label: 'Out of scope' },
  { id: 's08', num: '08', label: 'Edge cases' },
  { id: 's09', num: '09', label: 'Output' },
