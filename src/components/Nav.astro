---
interface Props {
  variant?: 'landing' | 'spec';
  tag?: string;
}

const { variant = 'landing', tag } = Astro.props;
---

<header class="nav">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="Portage home">
      <span class="brand-mark">P<span class="sl">//</span></span>
      <span class="brand-word">Portage</span>
    </a>
    {variant === 'landing' ? (
      <nav class="nav-links">
        <a href="/#routes">Routes</a>
        <a href="/#manifest">Manifest</a>
        <a href="/#docs">Docs</a>
        <a href="#" target="_blank" rel="noopener">GitHub</a>
        <a href="/#contact">Contact</a>
      </nav>
    ) : (
      <div class="nav-right" style="display:flex;align-items:center;gap:24px;">
        {tag && <span class="nav-tag">{tag}</span>}
        <a href="/">Home</a>
        <a href="/#routes">Routes</a>
      </div>
    )}
  </div>
</header>

<style>
.nav-right a {
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: 0.05em;
  color: var(--text-dim);
  transition: color .2s ease;
}
.nav-right a:hover {
  color: var(--cyan-bright);
}
.nav-tag {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-faint);
  border: 1px solid var(--line);
  padding: 4px 9px;
  border-radius: 3px;
}
@media (max-width: 600px) {
  .nav-tag {
    display: none;
  }
  .nav-right {
    gap: 16px !important;
  }
}
</style>
