---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
  origin: string;
  status: 'active' | 'beta' | 'planned';
  lede: string;
  meta: { k: string; v: string; cy?: boolean }[];
  toc: { id: string; num: string; label: string }[];
}

const { 
  title, 
  description = 'Portage route specification: migrating a publication to Astro. Field mapping, content transforms, assets, routes and redirects, limitations, edge cases, output schema, and CLI.',
  origin,
  status,
  lede,
  meta,
  toc
} = Astro.props;

const statusLabel = status.charAt(0).toUpperCase() + status.slice(1);
---

<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={Astro.url}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.ico">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Portage">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={Astro.url}>
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <script>document.documentElement.className='js';</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Outfit:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
  <Nav variant="spec" tag="Route Spec" />
  <main id="top">
    <section class="spec-hero">
      <svg class="hydro" viewBox="0 0 520 520" aria-hidden="true" style="position:absolute;right:-220px;top:-40px;width:520px;height:520px;z-index:0;pointer-events:none;opacity:0.7;">
        <defs>
          <path id="contour-spec" d="M -96,-46 C -60,-98 46,-102 88,-58 C 128,-18 100,60 42,86 C -14,108 -92,72 -106,16 C -118,-14 -122,-18 -96,-46 Z"/>
        </defs>
        <g transform="translate(300 240)">
          <use href="#contour-spec" transform="scale(0.55)" stroke-opacity="0.34"/>
          <use href="#contour-spec" transform="scale(0.85)" stroke-opacity="0.24"/>
          <use href="#contour-spec" transform="scale(1.18)" stroke-opacity="0.15"/>
          <use href="#contour-spec" transform="scale(1.55)" stroke-opacity="0.09"/>
        </g>
      </svg>
      <div class="wrap" style="max-width:1160px;">
        <p class="crumb"><a href="/">Portage</a> / Routes / <span>{origin} → Astro</span></p>
        <p class="spec-kicker">// Route specification</p>
        <h1 class="spec-title">{origin} <span class="arr">→</span> <span class="dest">Astro</span></h1>
        <p class="spec-lede">{lede}</p>
        <div class="hero-head-row">
          <span class={`badge ${status}`}><span class="dot"></span>{statusLabel}</span>
          <span class="meta-cell" style="background:var(--surface);border:1px solid var(--line);border-radius:6px;padding:8px 14px;"><span style="font-family:var(--mono);font-size:13px;color:var(--text-dim);">portage v0.9.2</span></span>
        </div>
        <div class="meta-grid">
          {meta.map((m) => (
            <div class="meta-cell"><div class="k">{m.k}</div><div class={`v${m.cy ? ' cy' : ''}`}>{m.v}</div></div>
          ))}
        </div>
      </div>
    </section>

    <div class="wrap" style="max-width:1160px;">
      <div class="spec-layout">
        <aside class="toc">
          <div class="toc-title">Contents</div>
          <nav class="toc-list">
            {toc.map((t) => (
              <a href={`#${t.id}`}><span class="n">{t.num}</span>{t.label}</a>
            ))}
          </nav>
        </aside>
        <div class="spec-body">
          <slot />
        </div>
      </div>
    </div>

    <footer class="foot" style="border-top:1px solid var(--line);padding:46px 0;">
      <div class="wrap" style="max-width:1160px;">
        <div class="foot-inner">
          <span style="font-family:var(--mono);font-size:13px;color:var(--text-dim);">Portage route spec · <a href="#top">{origin} → Astro</a></span>
          <div class="meta">
            <span>Salish Sea Consulting</span>
            <span>v0.9.2</span>
            <span>MIT</span>
          </div>
        </div>
      </div>
    </footer>
  </main>

  <script>
    (function(){
      if(!('IntersectionObserver' in window))return;
      var links=Array.prototype.slice.call(document.querySelectorAll('.toc a'));
      var map={};
      links.forEach(function(a){map[a.getAttribute('href').slice(1)]=a;});
      var spy=new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){
            links.forEach(function(l){l.classList.remove('active');});
            if(map[e.target.id])map[e.target.id].classList.add('active');
          }
        });
      },{rootMargin:'-20% 0px -72% 0px',threshold:0});
      document.querySelectorAll('.spec-sec').forEach(function(s){spy.observe(s);});
    })();
  </script>
</body>
</html>

<style>
  code {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--surface-2);
    color: var(--text);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--line);
  }

  /* badges */
  .badge {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 11px;
    border-radius: 3px;
    border: 1px solid var(--line);
    background: var(--surface);
  }
  .badge .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }
  .badge.active {
    color: var(--copper-bright);
    border-color: rgba(63, 110, 74, 0.4);
  }
  .badge.active .dot {
    background: var(--copper-bright);
    box-shadow: 0 0 0 3px rgba(63, 110, 74, 0.16);
  }
  .badge.beta {
    color: var(--amber-bright);
    border-color: rgba(142, 111, 59, 0.4);
  }
  .badge.beta .dot {
    background: var(--amber);
  }
  .badge.planned {
    color: var(--text-faint);
  }
  .badge.planned .dot {
    background: transparent;
    border: 1px solid var(--text-faint);
  }

  /* hero */
  .spec-hero {
    position: relative;
    overflow: hidden;
    padding: 60px 0 44px;
    border-bottom: 1px solid var(--line);
  }
  .crumb {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin-bottom: 22px;
  }
  .crumb a {
    color: var(--cyan);
  }
  .crumb a:hover {
    color: var(--cyan-bright);
  }
  .spec-kicker {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 16px;
  }
  .spec-title {
    font-size: clamp(38px, 6.4vw, 64px);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1;
  }
  .spec-title .arr {
    color: var(--amber);
  }
  .spec-title .dest {
    color: var(--cyan-bright);
  }
  .spec-lede {
    color: var(--text-dim);
    font-size: 18px;
    max-width: 620px;
    margin-top: 22px;
  }
  .hero-head-row {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 26px;
  }
  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 34px;
  }
  .meta-cell {
    background: var(--bg);
    padding: 14px 16px;
  }
  .meta-cell .k {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .meta-cell .v {
    font-family: var(--mono);
    font-size: 13.5px;
    color: var(--text);
    margin-top: 7px;
    word-break: break-word;
  }
  .meta-cell .v.cy {
    color: var(--cyan-bright);
  }

  /* layout */
  .spec-layout {
    display: grid;
    grid-template-columns: 212px 1fr;
    gap: 58px;
    align-items: start;
    padding: 54px 0 90px;
  }
  .toc {
    position: sticky;
    top: 88px;
  }
  .toc-title {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 16px;
  }
  .toc a {
    display: block;
    font-size: 14px;
    color: var(--text-dim);
    padding: 7px 0 7px 14px;
    border-left: 2px solid var(--line);
    transition: color .2s ease, border-color .2s ease;
  }
  .toc a .n {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-faint);
    margin-right: 8px;
  }
  .toc a:hover {
    color: var(--text);
  }
  .toc a.active {
    color: var(--cyan-bright);
    border-left-color: var(--cyan);
  }
  .toc a.active .n {
    color: var(--cyan);
  }

  /* spec content */
  .spec-sec {
    margin-bottom: 56px;
    scroll-margin-top: 92px;
  }
  .spec-sec > h2 {
    font-size: 27px;
    display: flex;
    align-items: baseline;
    gap: 13px;
    margin-bottom: 8px;
  }
  .spec-sec > h2 .num {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--amber);
    font-weight: 400;
  }
  .spec-sec h3 {
    font-size: 17px;
    margin: 28px 0 8px;
    color: var(--text);
  }
  .spec-sec p {
    color: var(--text-dim);
    margin: 12px 0;
  }
  .spec-sec strong {
    color: var(--text);
    font-weight: 600;
  }
  .spec-sec ul {
    list-style: none;
    margin: 14px 0;
  }
  .spec-sec li {
    color: var(--text-dim);
    padding: 6px 0 6px 24px;
    position: relative;
  }
  .spec-sec li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--amber);
  }
  .spec-sec li strong {
    color: var(--text);
  }

  /* tables */
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    margin: 20px 0;
  }
  table {
    border-collapse: collapse;
    width: 100%;
    min-width: 660px;
  }
  thead th {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
    text-align: left;
    padding: 13px 16px;
    border-bottom: 1px solid var(--line);
    background: var(--bg-deep);
    white-space: nowrap;
  }
  tbody td {
    padding: 13px 16px;
    border-bottom: 1px solid var(--line-soft);
    font-size: 14px;
    color: var(--text-dim);
    vertical-align: top;
  }
  tbody tr:last-child td {
    border-bottom: none;
  }
  .gf {
    font-family: var(--mono);
    color: var(--text);
    font-size: 12.5px;
  }
  .af {
    font-family: var(--mono);
    color: var(--cyan-bright);
    font-size: 12.5px;
  }
  .ty {
    font-family: var(--mono);
    color: var(--amber-bright);
    font-size: 12px;
  }
  .arrowcell {
    color: var(--amber);
    text-align: center;
    font-family: var(--mono);
    width: 34px;
  }

  /* notes */
  .note {
    border-left: 3px solid var(--cyan);
    background: var(--surface);
    padding: 15px 18px;
    border-radius: 0 7px 7px 0;
    margin: 20px 0;
  }
  .note .lbl {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cyan);
    display: block;
    margin-bottom: 7px;
  }
  .note p {
    margin: 0;
    color: var(--text-dim);
    font-size: 14.5px;
  }
  .note.warn {
    border-left-color: var(--amber);
  }
  .note.warn .lbl {
    color: var(--amber-bright);
  }
  .note.keep {
    border-left-color: var(--copper);
  }
  .note.keep .lbl {
    color: var(--copper-bright);
  }

  /* code blocks */
  .code {
    background: #12151A;
    border: 1px solid #23272E;
    border-radius: 7px;
    overflow: hidden;
    margin: 20px 0;
    box-shadow: 0 16px 36px -26px rgba(20, 32, 48, 0.4);
  }
  .code-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    border-bottom: 1px solid #23272E;
    background: #0D0F13;
  }
  .code-bar .name {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: #AEB6C2;
  }
  .code-bar .meta {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6B7480;
  }
  .code pre {
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.85;
    padding: 18px 20px;
    overflow-x: auto;
    white-space: pre;
    color: #E3E6EA;
  }
  .code .pr {
    color: #7FB0C6;
    user-select: none;
  }
  .code .fl {
    color: #CBAE7E;
  }
  .code .c {
    color: #6B7480;
  }
  .code .k {
    color: #7FB0C6;
  }
  .code .s {
    color: #A8C39B;
  }
  .code .t {
    color: #CBAE7E;
  }
  .code .out {
    color: #737C86;
  }

  /* footer */
  .foot-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 18px 28px;
    justify-content: space-between;
    align-items: center;
  }
  .foot-inner a {
    color: var(--cyan);
  }
  .foot-inner a:hover {
    color: var(--cyan-bright);
  }
  .foot-inner .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
  }
  .foot-inner .meta span {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }

  @media (max-width: 900px) {
    .spec-layout {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 30px 0 70px;
    }
    .toc {
      position: static;
      margin-bottom: 36px;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--line);
    }
    .toc-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .toc a {
      border-left: none;
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 6px 13px;
    }
    .toc a.active {
      border-color: var(--cyan);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>
